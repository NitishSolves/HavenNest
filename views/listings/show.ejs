<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-lg-8 offset-lg-2">

    <nav aria-label="Breadcrumb" class="mb-2">
      <a href="/listings" class="text-muted small text-decoration-none"><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Back to all stays</a>
    </nav>

    <div class="d-flex justify-content-between align-items-start gap-3">
      <h1 class="mb-1"><%= listing.title %></h1>
      <% if (currUser) { %>
        <form class="favorite-form flex-shrink-0" method="POST" action="/listings/<%= listing._id %>/favorite">
          <button type="submit" class="favorite-btn <%= isFavorited ? 'favorited' : '' %>" style="position: static;"
            aria-pressed="<%= isFavorited %>" aria-label="<%= isFavorited ? 'Remove from wishlist' : 'Add to wishlist' %>">
            <i class="<%= isFavorited ? 'fa-solid' : 'fa-regular' %> fa-heart" aria-hidden="true"></i>
          </button>
        </form>
      <% } %>
    </div>
    <p class="text-muted"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> <%= listing.location %>, <%= listing.country %></p>

    <div class="card col-12 show-card listing-card mb-4">
      <img src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>" class="card-img-top show-img" alt="<%= listing.title %>, a stay in <%= listing.location %>, <%= listing.country %>">
      <div class="card-body px-0">
        <p class="card-text">Hosted by <i><%= listing.owner ? listing.owner.username : "a HavenNest host" %></i></p>
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text fs-5"><b>&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></b> <span class="text-muted">/ night</span></p>
      </div>
    </div>

    <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) {%>
    <div class="btns mb-4">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary-hn edit-btn">Edit listing</a>
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-outline-danger-hn">Delete listing</button>
      </form>
    </div>
    <% } %>

    <hr>
    <h2 class="h4">Where you'll be</h2>
    <p class="text-muted small mb-2"><%= listing.location %>, <%= listing.country %></p>
    <div id="map" role="img" aria-label="Map showing the location of <%= listing.location %>, <%= listing.country %>"></div>
    <script>
      (function () {
        // The server (controllers/listings.js#showListing) geocodes and
        // persists geometry for any listing missing it *before* this page
        // renders, so `coords` should be present for the overwhelming
        // majority of requests. This client-side branch only exists as a
        // last-resort fallback for the rare case Nominatim failed both
        // server-side attempts (rate limit / transient network error) —
        // it does not duplicate that work on every page load.
        var coords = <%- JSON.stringify(listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates : null) %>;
        var locationText = <%- JSON.stringify(listing.location || "") %>;
        var countryText = <%- JSON.stringify(listing.country || "") %>;

        // Landmark-level zoom — most listings are a specific address or
        // point of interest, not a whole city, so 11 (city-level) rendered
        // an unhelpfully zoomed-out map. 15 reads correctly for both.
        var LANDMARK_ZOOM = 15;

        function addMap(lat, lng, label) {
          var map = L.map("map", { scrollWheelZoom: false }).setView([lat, lng], LANDMARK_ZOOM);

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
            maxZoom: 18,
          }).addTo(map);

          L.marker([lat, lng], {
            icon: L.icon({
              iconUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png",
              iconRetinaUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png",
              shadowUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
              iconSize: [25, 41],
              iconAnchor: [12, 41],
            }),
          })
            .addTo(map)
            .bindPopup(label)
            .openPopup();
        }

        function renderUnavailable() {
          var mapEl = document.getElementById("map");
          mapEl.innerHTML = '<div class="map-unavailable"><span><i class="fa-solid fa-map-location-dot me-2" aria-hidden="true"></i>We couldn\'t locate this stay on the map right now. Try refreshing the page.</span></div>';
        }

        if (Array.isArray(coords) && coords.length === 2) {
          addMap(coords[1], coords[0], locationText + (countryText ? ", " + countryText : ""));
          return;
        }

        var query = [locationText, countryText].filter(Boolean).join(", ");
        if (!query) {
          renderUnavailable();
          return;
        }

        fetch("https://nominatim.openstreetmap.org/search?format=json&limit=1&q=" + encodeURIComponent(query), {
          headers: { "Accept": "application/json" },
        })
          .then(function (res) { return res.ok ? res.json() : []; })
          .then(function (results) {
            if (!Array.isArray(results) || !results.length) {
              renderUnavailable();
              return;
            }
            addMap(parseFloat(results[0].lat), parseFloat(results[0].lon), query);
          })
          .catch(renderUnavailable);
      })();
    </script>

    <div class="mt-5">
      <% if(currUser) { %>
        <h2 class="h4">Leave a review</h2>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation surface-card">
          <div class="mb-3">
            <label for="rating" class="form-label d-block">Rating</label>
            <fieldset class="starability-slot">
              <legend class="visually-hidden">Star rating</legend>
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" id="comment" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">Please write a comment for your review.</div>
          </div>
          <button class="btn btn-primary-hn">Submit review</button>
        </form>
        <hr class="mt-4">
      <% } %>

      <% if(listing.reviews.length > 0) {%>
        <h2 class="h4 mb-3">All reviews <span class="text-muted">(<%= listing.reviews.length %>)</span></h2>
        <div class="row g-3">
          <% for(review of listing.reviews){ %>
          <div class="col-md-6">
            <div class="card surface-card h-100">
              <div class="card-body px-0 pt-0">
                <h3 class="h6 card-title">@<%= review.author ? review.author.username : "deleted user" %></h3>
                <p class="starability-result card-text" data-rating="<%= review.rating %>" aria-label="Rated <%= review.rating %> out of 5"></p>
                <p class="card-text"><%= review.comment %></p>

                <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                  <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-outline-danger-hn">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
