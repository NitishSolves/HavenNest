<% layout("/layouts/boilerplate") %>
<article class="show-page">
  <header class="show-header"><p class="eyebrow"><%= listing.location %>, <%= listing.country %></p><h1><%= listing.title %></h1><p><%= listing.reviews.length %> reviews · Hosted by <%= listing.owner ? listing.owner.username : 'HavenNest host' %></p></header>
  <section class="show-hero"><img src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>" alt="<%= listing.title %>" class="show-img"><button class="favorite-btn show-fav" type="button" data-favorite-id="<%= listing._id %>" aria-label="Save <%= listing.title %> to favorites"><i class="fa-regular fa-heart"></i></button></section>
  <div class="show-layout">
    <section class="show-content"><h2>About this stay</h2><p><%= listing.description %></p><div class="detail-grid"><div><b>Nightly rate</b><span>₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span></div><div><b>Destination</b><span><%= listing.country %></span></div><div><b>Category</b><span><%= listing.category || 'trending' %></span></div></div>
      <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) {%><div class="owner-actions"><a href="/listings/<%= listing._id %>/edit" class="btn btn-primary-brand">Edit listing</a><form method="POST" action="/listings/<%= listing._id %>?_method=DELETE"><button class="btn btn-outline-danger">Delete</button></form></div><% } %>
      <section class="map-section"><h2>Where you'll be</h2><p class="text-muted">Map is approximate for guest privacy.</p><div id="map" data-location="<%= `${listing.location}, ${listing.country}` %>" aria-label="Map showing approximate listing location"></div></section>
      <section class="reviews-section"><% if(currUser) { %><hr><h2>Leave a review</h2><form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation review-form"><label for="rating" class="form-label">Rating</label><fieldset class="starability-slot"><input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." /><input type="radio" id="first-rate1" name="review[rating]" value="1" /><label for="first-rate1" title="Terrible">1 star</label><input type="radio" id="first-rate2" name="review[rating]" value="2" /><label for="first-rate2" title="Not good">2 stars</label><input type="radio" id="first-rate3" name="review[rating]" value="3" /><label for="first-rate3" title="Average">3 stars</label><input type="radio" id="first-rate4" name="review[rating]" value="4" /><label for="first-rate4" title="Very good">4 stars</label><input type="radio" id="first-rate5" name="review[rating]" value="5" /><label for="first-rate5" title="Amazing">5 stars</label></fieldset><label for="comment" class="form-label">Comments</label><textarea name="review[comment]" id="comment" rows="5" class="form-control" required></textarea><div class="invalid-feedback">Please write a review comment.</div><button class="btn btn-primary-brand mt-3">Submit review</button></form><% } %>
      <% if(listing.reviews.length > 0) {%><div class="review-grid"><h2>Guest reviews</h2><% for(review of listing.reviews){ %><div class="card review-card"><div class="card-body"><h3>@<%= review.author.username %></h3><p class="starability-result" data-rating="<%=review.rating %>"></p><p><%=review.comment %></p><form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"><button class="btn btn-sm btn-outline-dark">Delete</button></form></div></div><% } %></div><% } %></section>
    </section>
    <aside class="booking-card"><p class="price">₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %><span>/night</span></p><button class="btn btn-primary-brand w-100">Request to book</button><p>No charge today. Exact location is shared after booking.</p></aside>
  </div>
</article>
