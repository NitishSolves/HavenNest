<% layout("/layouts/boilerplate") %><div class="form-page"><h1>Edit your HavenNest listing</h1><form method="POST" action="/listings/<%= listing._id%>?_method=PUT" class="needs-validation listing-form" novalidate enctype="multipart/form-data"><label for="title" class="form-label">Title</label><input id="title" name="listing[title]" value="<%= listing.title %>" type="text" class="form-control" required/><label for="description" class="form-label">Description</label><textarea id="description" name="listing[description]" class="form-control" required><%= listing.description %></textarea><% if (originalImageUrl) { %><div><p class="form-label">Current image</p><img class="edit-preview" src="<%= originalImageUrl %>" alt="Current listing image" /></div><% } %><label for="image" class="form-label">Upload new image</label><input id="image" name="listing[image]" type="file" accept="image/png,image/jpeg" class="form-control"><div class="row"><div class="col-md-4"><label for="price" class="form-label">Price</label><input id="price" name="listing[price]" value="<%= listing.price %>" type="number" min="0" class="form-control" required></div><div class="col-md-8"><label for="country" class="form-label">Country</label><input id="country" name="listing[country]" value="<%= listing.country %>" type="text" class="form-control" required></div></div><label for="location" class="form-label">City or area</label><input id="location" name="listing[location]" value="<%= listing.location %>" type="text" class="form-control" required><label for="category" class="form-label">Category</label><select id="category" name="listing[category]" class="form-select" required><% categories.forEach((category) => { %><option value="<%= category.key %>" <%= listing.category === category.key ? 'selected' : '' %>><%= category.label %></option><% }) %></select><button class="btn btn-primary-brand mt-3">Save changes</button></form></div>
