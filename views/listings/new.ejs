<% layout("/layouts/boilerplate") %><div class="form-page"><h1>List your stay on HavenNest</h1><p class="text-muted">Create a polished, searchable listing with a clear location and travel style.</p><form method="POST" action="/listings" novalidate class="needs-validation listing-form" enctype="multipart/form-data"><label class="form-label" for="title">Title</label><input id="title" name="listing[title]" placeholder="Modern loft near downtown" type="text" class="form-control" required><label class="form-label" for="description">Description</label><textarea id="description" name="listing[description]" placeholder="Describe the atmosphere, amenities, and best-fit guests." class="form-control" required></textarea><label class="form-label" for="image">Upload listing image</label><input id="image" name="listing[image]" type="file" accept="image/png,image/jpeg" class="form-control" required><div class="row"><div class="col-md-4"><label for="price" class="form-label">Price</label><input id="price" name="listing[price]" placeholder="1500" type="number" min="0" class="form-control" required></div><div class="col-md-8"><label for="country" class="form-label">Country</label><input id="country" name="listing[country]" placeholder="United States" type="text" class="form-control" required></div></div><label for="location" class="form-label">City or area</label><input id="location" name="listing[location]" placeholder="Malibu" type="text" class="form-control" required><label for="category" class="form-label">Category</label><select id="category" name="listing[category]" class="form-select" required><% categories.forEach((category) => { %><option value="<%= category.key %>"><%= category.label %></option><% }) %></select><button class="btn btn-primary-brand mt-3">Publish listing</button></form></div>
