<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-5">
  <div class="col-lg-7 offset-lg-2">
    <h1>Create a HavenNest</h1>
    <p class="text-muted mb-4">Tell us about your place — you can edit any of this later.</p>

    <form method="POST" action="/listings" novalidate class="needs-validation surface-card" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input id="title" name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required maxlength="100">
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">Please enter a title.</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea id="description" name="listing[description]" placeholder="What makes this place special?" class="form-control" rows="4" required></textarea>
        <div class="invalid-feedback">Please enter a short description.</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Listing photo</label>
        <input id="image" name="listing[image]" type="file" accept="image/png, image/jpeg" class="form-control" required>
        <div class="invalid-feedback">Please upload a photo.</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price per night (&#8377;)</label>
          <input id="price" name="listing[price]" placeholder="e.g. 1500" type="number" min="0" class="form-control" required>
          <div class="invalid-feedback">Enter a valid price.</div>
        </div>
        <div class="mb-3 col-md-8">
          <label for="category" class="form-label">Category</label>
          <select id="category" name="listing[category]" class="form-select" required>
            <% for (let cat of categories) { %>
              <option value="<%= cat.value %>"><%= cat.label %></option>
            <% } %>
          </select>
        </div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label for="location" class="form-label">City / area</label>
          <input id="location" name="listing[location]" placeholder="e.g. Malibu" type="text" class="form-control" required>
          <div class="invalid-feedback">Enter a location.</div>
        </div>
        <div class="mb-3 col-md-6">
          <label for="country" class="form-label">Country</label>
          <input id="country" name="listing[country]" placeholder="e.g. United States" type="text" class="form-control" required>
          <div class="invalid-feedback">Enter a country.</div>
        </div>
      </div>
      <p class="text-muted small">We'll place your listing on the map automatically from the city and country you enter.</p>

      <button class="btn btn-primary-hn mt-2" type="submit">Publish listing</button>
    </form>
  </div>
</div>