<% layout("/layouts/boilerplate") %><div class="auth-page"><h1>Join HavenNest</h1><p class="text-muted">Create an account to host, review, and favorite curated stays.</p><form action="/signup" method="POST" class="needs-validation auth-card" novalidate><label for="username" class="form-label">Username</label><input name="username" id="username" type="text" class="form-control" required><label for="email" class="form-label">Email</label><input name="email" id="email" type="email" class="form-control" required><label for="password" class="form-label">Password</label><input name="password" id="password" type="password" class="form-control" required><button class="btn btn-primary-brand w-100 mt-3">Create account</button></form></div>
