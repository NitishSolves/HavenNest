<% if (typeof success !== "undefined" && success && success.length) { %>
<div class="alert alert-success alert-dismissible fade show col-lg-8 offset-lg-2 mt-3" role="status">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<% if (typeof error !== "undefined" && error && error.length) { %>
<div class="alert alert-danger alert-dismissible fade show col-lg-8 offset-lg-2 mt-3" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>
