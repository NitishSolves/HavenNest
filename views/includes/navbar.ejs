<style>
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .theme-toggle {
    appearance: none;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--bg-elevated), rgba(31, 111, 92, 0.06));
    color: var(--text);
    border-radius: 999px;
    width: 2.8rem;
    height: 2.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
    padding: 0;
  }

  .theme-toggle:hover {
    background: linear-gradient(180deg, var(--hn-teal-100), var(--bg-elevated));
    box-shadow: var(--shadow-hover);
    transform: translateY(-1px);
  }

  .theme-toggle:active {
    transform: translateY(0);
  }

  .theme-toggle i {
    font-size: 1rem;
    line-height: 1;
  }
</style>

<nav class="navbar navbar-expand-md sticky-top" aria-label="Main navigation">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings">
        <i class="fa-regular fa-compass" aria-hidden="true"></i> HavenNest
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
        </div>

        <div class="navbar-nav ms-md-3 align-items-md-center nav-actions ms-auto">
          <a class="nav-link fw-semibold" href="/listings/new">Create a HavenNest</a>
          <% if(currUser) { %>
            <a class="nav-link" href="/wishlist"><i class="fa-solid fa-heart" aria-hidden="true"></i> Wishlist</a>
          <% } %>
          <button id="theme-toggle" class="theme-toggle nav-link" type="button" aria-pressed="false" aria-label="Toggle dark mode">
            <i class="fa-solid fa-moon" aria-hidden="true"></i>
          </button>
          <% if(!currUser){ %>
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
            <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } %>
          <% if(currUser) { %>
            <a class="nav-link" href="/logout">Log out</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>