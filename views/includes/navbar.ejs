<style>
  .search-btn{
    background-color: var(--hn-teal-600);
    color:#fff;
    border-radius: 25px;
    padding: 0 1.1rem;
    border: none;
  }
  .search-btn:hover{
    background-color: var(--hn-teal-700);
    color:#fff;
  }
  .search-btn i{
    display: inline;
    margin-right:0.4rem;
  }
  .search-inp{
    border-radius: 25px;
    padding: 0.5rem 1.25rem;
    font-size: 1rem;
    border: 1px solid var(--border);
    background-color: var(--bg-elevated);
    color: var(--text);
  }
</style>

<nav class="navbar navbar-expand-md sticky-top" aria-label="Main navigation">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings">
        <i class="fa-regular fa-compass" aria-hidden="true"></i> HavenNest
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
        </div>
        <div class="navbar-nav ms-auto flex-grow-1 flex-md-grow-0">
            <form class="d-flex" role="search" action="/listings" method="GET" aria-label="Search listings">
                <label for="nav-search" class="visually-hidden">Search by city or listing name</label>
                <input class="form-control me-2 search-inp" id="nav-search" name="q" type="search" placeholder="Search destinations" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" aria-label="Search"/>
                <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i><span class="d-none d-sm-inline">Search</span></button>
              </form>
        </div>

        <div class="navbar-nav ms-md-3 align-items-md-center">
          <a class="nav-link" href="/listings/new">HavenNest your home</a>
          <% if(currUser) { %>
            <a class="nav-link" href="/wishlist"><i class="fa-solid fa-heart" aria-hidden="true"></i> Wishlist</a>
          <% } %>
          <button id="theme-toggle" class="theme-toggle nav-link" type="button" aria-pressed="false" aria-label="Toggle dark mode">
            <i class="fa-solid fa-moon" aria-hidden="true"></i>
          </button>
          <% if(!currUser){ %>
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
            <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } %>
          <% if(currUser) { %>
            <a class="nav-link" href="/logout">Log out</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>
