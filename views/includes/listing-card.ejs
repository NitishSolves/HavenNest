<% let isFav = false; if (typeof currUser !== "undefined" && currUser &&
currUser.favorites) { for (let i = 0; i < currUser.favorites.length; i++) { if
(currUser.favorites[i].toString() === listing._id.toString()) { isFav = true;
break; } } } let locationLine = ""; if (listing.location) { locationLine =
listing.location; } if (listing.country) { if (locationLine) { locationLine =
locationLine + ", " + listing.country; } else { locationLine = listing.country;
} } let price = "N/A"; if (listing.price) { price =
listing.price.toLocaleString("en-IN"); } %>
<div class="col">
  <div class="listing-card-wrap">
    <a
      href="/listings/<%= listing._id %>"
      class="listing-link"
      aria-label="View <%= listing.title %> in <%= listing.location %>"
    >
      <article class="card listing-card">
        <div class="card-img-wrap">
          <img
            src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>"
            class="card-img-top"
            alt="<%= listing.title %>, a stay in <%= listing.location %>, <%= listing.country %>"
            loading="lazy"
          />
          <div class="card-img-overlay"></div>
        </div>
        <div class="card-body listing-card-body">
          <p class="listing-meta"><%= locationLine %></p>
          <h3 class="listing-card-title"><%= listing.title %></h3>
          <div class="listing-card-footer">
            <span class="listing-price">₹<%= price %></span>
            <span class="listing-price-note">/ night</span>
          </div>
        </div>
      </article>
    </a>

    <% if (typeof currUser !== "undefined" && currUser) { %>
    <form
      class="favorite-form"
      method="POST"
      action="/listings/<%= listing._id %>/favorite"
    >
      <button
        type="submit"
        class="favorite-btn <% if (isFav) { %>favorited<% } %>"
        aria-pressed="<%= isFav %>"
        aria-label="<% if (isFav) { %>Remove from wishlist<% } else { %>Add to wishlist<% } %>"
      >
        <i
          class="<% if (isFav) { %>fa-solid<% } else { %>fa-regular<% } %> fa-heart"
        ></i>
      </button>
    </form>
    <% } %>
  </div>
</div>
