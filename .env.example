# MongoDB Atlas (or local) connection string
ATLASDB_URL=mongodb+srv://<user>:<password>@<cluster>/havennest

# Cloudinary (image storage)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Session signing secret — generate a long random string for production
SECRET=

# Only needed when running `npm run seed`: the _id of an existing User
# document that seeded listings will be assigned as owner.
SEED_OWNER_ID=

# development | production
NODE_ENV=development
PORT=8080
